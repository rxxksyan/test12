{
  "name": "IYHAN_SHOP",
  "version": "1.0.3",
  "scripts": {
    "dev": "concurrently \"nodemon --exec ts-node server/index.ts\" \"tsc -p tsconfig.client.json --watch\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "start": "node dist/index.js"
  },
  "nodemonConfig": {
    "watch": ["server"],
    "ext": "ts",
    "ignore": ["*.json", "public/*", "src/*"]
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.4.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}